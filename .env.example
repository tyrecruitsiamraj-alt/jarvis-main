# =============================================================================
# ความลับใส่แค่บนเครื่องคุณ — ไม่ส่งให้ AI / ไม่ commit
# =============================================================================
# 1) คัดลอกไฟล์นี้เป็น `.env.local` (แนะนำ) หรือ `.env`
# 2) แก้ค่าด้านล่างให้ตรงกับ DBeaver / ที่ IT ให้มา
# 3) ทดสอบ: npm run db:ping → npm run db:migrate → npm run db:seed
# 4) (ทางเลือก) ดึงข้อมูลตัวอย่างจาก mockData เข้า DB: npm run db:seed:demo
# 5) รันแอปกับ API: npm run dev (API + Vite พร้อมกัน) หรือ npm run dev:local เหมือนกัน
#
# ลำดับโหลด: `.env` ก่อน แล้ว `.env.local` ทับ (migrate / seed / db:ping / API ใช้แบบนี้)
# ไฟล์ `.env` และ `.env.local` อยู่ใน .gitignore แล้ว
#
# โหมดท้องถิ่น: `npm run dev` (แนะนำ) หรือ `npm run api:local` + `npm run dev:vite` แยกสองเทอร์มินัล
# โหมด Vercel: ตั้ง Environment Variables ในโปรเจกต์ Vercel (Production + Preview) แทนไฟล์
#   บังคับ: DATABASE_URL, PGSCHEMA, PG_SSL, AUTH_JWT_SECRET, CORS_ALLOWED_ORIGINS
#   Build-time: VITE_DEMO_MODE (ถ้าใช้โหมดสาธิต)
#   Auth (production): JARVIS_DEV_ROLE_LOGIN ต้องไม่ตั้งเป็น true
#   CORS_ALLOWED_ORIGINS=https://your-app.vercel.app (คั่นด้วย comma ถ้ามีหลาย origin)
# APP_PUBLIC_URL=https://your-app.vercel.app (สำหรับลิงก์ magic link / รีเซ็ตรหัสผ่านในอีเมล)
#   GOOGLE_MAPS_API_KEY, SEED_USER_PASSWORD (แค่ตอน seed บนเครื่อง)
#   Deploy: npm run deploy:vercel  (หรือ npx vercel deploy --prod --yes)
#   หลัง Deploy: Settings → แท็บ Vercel IP — เช็ก Outbound IP ไป allowlist ที่ firewall DB/MSSQL
#   บันทึก IP ลง PostgreSQL: npm run db:migrate (023_outbound_ip_logs.sql)
# =============================================================================

# --- Frontend (Vite เท่านั้น — ไม่ใส่รหัส DB ตรงนี้) ---
# ใช้ Postgres + login จริง (production): ปิดโหมดสาธิตทั้งคู่
# VITE_DEMO_MODE=false
# VITE_ENABLE_RUNTIME_DEMO_FALLBACK=false
#
# โหมดสาธิตเต็มรูปแบบ (local demo เท่านั้น):
# VITE_DEMO_MODE=true
#
# เปิด fallback ชั่วคราวเมื่อ API ล้ม (development เท่านั้น — production build ปิดเสมอ):
# VITE_ENABLE_RUNTIME_DEMO_FALLBACK=true

# API เลือกสิทธิ์ (POST /api/auth/dev-role) — เฉพาะ development เท่านั้น
# เปิดได้เมื่อ: NODE_ENV และ VERCEL_ENV ไม่ใช่ production และตั้งค่าเป็น true
# JARVIS_DEV_ROLE_LOGIN=true

# CORS whitelist (production บังคับ) — ตัวอย่าง:
# CORS_ALLOWED_ORIGINS=https://jarvis-main-five.vercel.app,http://localhost:5173

# เปิดการสมัครสมาชิกเอง (เปิดโดยค่าเริ่มต้น — ตั้ง false เพื่อปิด)
# JARVIS_ALLOW_PUBLIC_REGISTER=false

# Connection string (ไม่มีช่องว่าง)
# ถ้าได้ "Invalid username/password, login denied" → user/password ใน URL ไม่ตรงกับที่ PostgreSQL รับ
# ให้ก็อปจาก DBeaver (คนละ user กับ MySQL: มักเป็น postgres ไม่ใช่ root)
# รหัสมี @ : / ? # ต้อง encode (เช่น my@pass → my%40pass)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE_NAME

# schema ใน DBeaver (ตาราง candidates/jobs/employees อยู่ schema นี้)
PGSCHEMA=jarvis_rm

# --- Siamraj ใบขอหน่วยงาน (อ่านอย่างเดียวจาก so-operation บน DB เดียวกับ DATABASE_URL) ---
# เมื่อตั้งค่าแล้ว หน้า "หน่วยงาน" จะแสดงคิวใบขอจาก Siamraj แทนการคีย์ใน Jarvis
# SIAMRAJ_SCHEMA=so-operation
# SO_OPERATION_SCHEMA=so-operation
# SIAMRAJ_UNIT_REQUESTS_ENABLED=true
# staffing_queue = กรองเฉพาะใบขอลาออก/เปลี่ยน | all = ตาม query st_request_* เต็ม (default)
# SIAMRAJ_UNIT_REQUESTS_MODE=all
# ต้อง GRANT USAGE ON SCHEMA "so-operation" และ SELECT บนตาราง activity_to_saleco_* ให้ DB user

# --- Siamraj SQL Server (ใบขอ st_request_* บน 172.16.0.36) — ถ้ามี DB_HOST จะใช้แหล่งนี้ก่อน so-operation ---
# DB_HOST=172.16.0.36
# DB_HOST=110.49.94.165,7111
# DB_PORT=1433
# DB_USER=team.dashboard
# DB_PASSWORD=your-password
# DB_NAME=Siamraj
# DB_ENCRYPT=false
# DB_TRUST_SERVER_CERTIFICATE=true
# ตัวกรอง query st_request_* (SQL Server)
# SIAMRAJ_SQL_YEAR=2026
# SIAMRAJ_SQL_DEPT_FROM=_
# SIAMRAJ_SQL_DEPT_TO=Z
# SIAMRAJ_SQL_SITE_FROM=_
# SIAMRAJ_SQL_SITE_TO=Z
# SIAMRAJ_DB_SOURCE=auto
# auto = ใช้ SQL Server ถ้ามี DB_HOST (ไม่ fallback ไป PostgreSQL)

# เซิร์ฟเวอร์ภายนอกมักต้องเปิด SSL — ถ้าเชื่อมไม่ได้ลอง false
PG_SSL=true

# ถ้าไม่ต้องการให้ API อ่าน .env.local ทับตัวแปร (เช่น debug)
# JARVIS_SKIP_LOCAL_ENV=1

# พอร์ต API แบบท้องถิ่น (server/local-api.ts) — ต้องตรงกับ VITE_API_PROXY_TARGET ถ้าเปลี่ยน
# LOCAL_API_PORT=3000

# ถ้า vercel dev ไปที่พอร์ตอื่น (เช่น 3000 ถูกใช้แล้ว) ให้ตรงกับพอร์ตนั้น
# VITE_API_PROXY_TARGET=http://localhost:3001

# ถ้าใช้ Geocoding
# GOOGLE_MAPS_API_KEY=

# --- Auth (production / local API) ---
# จำเป็นสำหรับ login และ endpoint ที่ต้องล็อกอิน (candidates, jobs, employees)
AUTH_JWT_SECRET=replace-with-long-random-secret-at-least-32-characters

# อายุ token (วินาที) — default 1800
# AUTH_TOKEN_TTL_SECONDS=1800

# ชื่อคุกกี้ (default jarvis_auth)
# AUTH_COOKIE_NAME=jarvis_auth

# Lax หรือ strict (production + HTTPS แนะนำ Lax)
# AUTH_COOKIE_SAMESITE=strict

# รหัสผ่านเริ่มต้นของผู้ใช้ที่ seed (npm run db:seed)
# SEED_USER_PASSWORD=ChangeMe123!

# (ทางเลือก) สร้าง/อัปเดต admin คนเดียว — ใส่เฉพาะใน .env.local อย่า commit
# รัน npm run db:seed หลังตั้งค่า — จะลด admin คนอื่นเป็น staff โดย default
# SEED_SOLE_ADMIN_EMAIL=
# SEED_SOLE_ADMIN_PASSWORD=
# SEED_SOLE_ADMIN_NAME=
# SEED_SOLE_ADMIN_DEMOTE_OTHERS=true

# --- Email (Postmark) — login ด้วยอีเมลบริษัท + ลืมรหัสผ่าน ---
# POSTMARK_SERVER_TOKEN=your-postmark-server-token
# EMAIL_SENDER=no-reply-support@siamraj.com
# APP_PUBLIC_URL=https://your-app.vercel.app
# โดเมนอีเมลบริษัทที่อนุญาต (default จาก EMAIL_SENDER → siamraj.com)
# JARVIS_COMPANY_EMAIL_DOMAINS=siamraj.com
# MAGIC_LINK_TTL_MINUTES=15
# PASSWORD_RESET_TTL_MINUTES=60

# --- Azure AD (Microsoft SSO) — แทน magic link บนปุ่ม Microsoft เมื่อตั้งค่าครบ ---
# AZURE_AD_TENANT_ID=your-tenant-id
# AZURE_AD_CLIENT_ID=your-app-client-id
# AZURE_AD_CLIENT_SECRET=your-client-secret
# APP_PUBLIC_URL=https://your-app.example.com  (redirect = {APP_PUBLIC_URL}/api/auth/azure-ad/callback)
# AZURE_AD_SCOPES=openid profile email User.Read
# AUTH_TOKEN_TTL_SECONDS=28800  (8 ชม. — แนะนำเมื่อใช้ SSO)

# --- Driver Care (ทางเลือก — สำหรับ Vercel Cron ในอนาคต) ---
# DRIVER_CARE_CRON_SECRET=replace-with-long-random-secret
